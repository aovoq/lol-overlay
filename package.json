{
  "name": "lol-overlay",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "test:frontend": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "pnpm format:frontend && pnpm format:rust && pnpm format:toml",
    "format:check": "pnpm format:frontend:check && pnpm format:rust:check && pnpm format:toml:check",
    "format:frontend": "biome check --write .",
    "format:frontend:check": "biome ci .",
    "format:rust": "cargo fmt --all",
    "format:rust:check": "cargo fmt --all -- --check",
    "format:toml": "taplo fmt Cargo.toml src-tauri/Cargo.toml crates/*/Cargo.toml",
    "format:toml:check": "taplo fmt --check --diff Cargo.toml src-tauri/Cargo.toml crates/*/Cargo.toml",
    "lint": "pnpm lint:frontend && pnpm lint:rust",
    "lint:frontend": "biome lint .",
    "lint:rust": "cargo clippy --workspace --all-targets -- -D warnings",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:frontend && cargo test --workspace --lib",
    "tauri": "tauri"
  },
  "dependencies": {
    "@msviderok/base-ui-solid": "1.0.0-beta.12",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@tailwindcss/vite": "^4.3.0",
    "@taplo/cli": "0.7.0",
    "@tauri-apps/cli": "^2",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  }
}
