# Cloudflare Worker origin used by the desktop pairing UI.
# Local relay: http://127.0.0.1:8787
VITE_MOBILE_RELAY_URL=https://lol-overlay-relay.voq.workers.dev
# Expo mobile app uses the same Relay when resolving 6-digit connection codes.
EXPO_PUBLIC_MOBILE_RELAY_URL=https://lol-overlay-relay.voq.workers.dev

# Optional. Must match the Worker secret SESSION_CREATE_SECRET when that is set.
# Loaded by the Tauri process at runtime (not baked into the frontend bundle).
MOBILE_RELAY_CREATE_SECRET=
