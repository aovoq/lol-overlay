# Shared Cloudflare Worker origin used by both desktop and mobile.
# Keep this file at the repository root; all root-level dev/build commands load it.
# GitHub release builds: repository variable EXPO_PUBLIC_MOBILE_RELAY_URL.
# Local relay: http://127.0.0.1:8787
EXPO_PUBLIC_MOBILE_RELAY_URL=https://lol-overlay-relay.voq.workers.dev

# Optional locally. Production Relay and desktop must use the same value.
# Store the production value in both places:
#   cd apps/relay && bunx wrangler secret put MOBILE_RELAY_CREATE_SECRET
#   GitHub repository secret MOBILE_RELAY_CREATE_SECRET
# Loaded by the Tauri process at runtime (not baked into the frontend bundle).
MOBILE_RELAY_CREATE_SECRET=

# Tauri updater signing key. Required only when building updater artifacts locally.
# Tauri does not load these values automatically; export them in the shell before
# running `bun run tauri build`. Keep the real private key out of git.
TAURI_SIGNING_PRIVATE_KEY=

# Optional. Leave empty when the signing key has no password.
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
