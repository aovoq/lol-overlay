# Tauri updater signing key.
# Required only when building updater artifacts locally.
#
# Tauri does not load this file automatically for updater signing.
# Source/copy these values into your shell before running `bun run tauri build`.
#
# Keep the real private key out of git. GitHub Actions uses the
# TAURI_SIGNING_PRIVATE_KEY repository secret for release builds.

# Path to the private key file, or the private key content itself.
TAURI_SIGNING_PRIVATE_KEY=

# Optional. Leave empty when the signing key has no password.
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
